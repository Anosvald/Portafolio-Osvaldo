---
import Layout from "../layouts/Layout.astro" 

import AboutMe from "../components/AboutMe.astro"
import Information from "../components/Informacion.astro" 
import Briefcase from "../components/Icons/Briefcase.astro"
import Certificate from "../components/Icons/Certificate.astro"
import CodeIcon from "../components/Icons/Code.astro"
import CodeIcon1 from "../components/Icons/codee.astro"
import Experience from "../components/Experience.astro"
import ProfileCheck from "../components/Icons/ProfileCheck.astro"
import Projects from "../components/Projects.astro"
import SectionContainer from "../components/SectionContainer.astro"
import Hero from "../components/Hero.astro"
import TitleSection from "../components/TitleSection.astro"
import Awards from "../components/Awards.astro" 
import Bulb from "../components/Icons/Bulb.astro"
import Contacto from '../components/Contacto.astro'
import Create from '../components/Create.astro'
---

<Layout
  title="Portafolio de Osvaldo"
  description="Portafolio profesional de Diego Osvaldo Hernández Fernández, estudiante de Ingeniería en TI enfocado en ciberseguridad, pentesting y respuesta a incidentes."
>

  {/* ============================================================ */}
  {/* MEJORA 1 — BARRA DE PROGRESO DE SCROLL NEÓN (top)            */}
  {/* ============================================================ */}
  <div
    id="scroll-progress"
    class="fixed top-0 left-0 h-[2px] pointer-events-none"
    style="z-index: 9999; width: 0%; background: linear-gradient(90deg, #00ff41, #00cfff, #00ff41); box-shadow: 0 0 8px #00ff41, 0 0 16px #00ff4180; transition: width 0.1s linear;"
  ></div>

  {/* ============================================================ */}
  {/* MEJORA 3 — CURSOR GLOW (solo desktop)                        */}
  {/* ============================================================ */}
  <div
    id="cursor-glow"
    class="fixed pointer-events-none hidden md:block"
    style="z-index: 9998; width: 300px; height: 300px; border-radius: 50%; background: radial-gradient(circle, rgba(0,255,65,0.045) 0%, transparent 70%); transform: translate(-50%, -50%); transition: left 0.12s ease, top 0.12s ease; top: -999px; left: -999px;"
  ></div>

  {/* ============================================================ */}
  {/* CAPA DE FONDO: MATRIX RAIN CANVAS (z-index bajo, fijo)       */}
  {/* ============================================================ */}
  <canvas
    id="matrix-canvas"
    class="fixed top-0 left-0 w-full h-full pointer-events-none"
    style="z-index: 0; opacity: 0.04;"
  ></canvas>

  {/* ============================================================ */}
  {/* OVERLAY SCANLINES estilo CRT                                 */}
  {/* ============================================================ */}
  <div
    id="scanlines"
    class="fixed top-0 left-0 w-full h-full pointer-events-none"
    style="z-index: 1; opacity: 0.025;"
  ></div>

  {/* ============================================================ */}
  {/* HUD CORNERS - decoración esquinas top                        */}
  {/* ============================================================ */}
  <div class="fixed top-4 left-4 pointer-events-none z-10 hidden md:block">
    <div class="hud-corner-tl text-green-500/40 font-mono text-xs leading-tight">
      <div class="flex items-center gap-2 mb-1">
        <span class="inline-block w-2 h-2 rounded-full bg-green-500/60 animate-pulse"></span>
        <span>SYS:ONLINE</span>
      </div>
      <div class="text-green-500/25">0x4F56414C444F</div>
    </div>
  </div>

  <div class="fixed top-4 right-4 pointer-events-none z-10 hidden md:block text-right">
    <div class="text-green-500/40 font-mono text-xs leading-tight">
      <div class="flex items-center justify-end gap-2 mb-1">
        <span id="hud-time" class="tabular-nums">00:00:00</span>
        <span class="inline-block w-2 h-2 rounded-full bg-blue-400/60 animate-pulse"></span>
      </div>
      <div class="text-green-500/25">IPv6::SECURED</div>
    </div>
  </div>

  {/* ============================================================ */}
  {/* BARRA DE ESTADO INFERIOR (HUD bottom)                        */}
  {/* ============================================================ */}
  <div class="fixed bottom-0 left-0 right-0 pointer-events-none z-10 hidden md:flex items-center justify-between px-6 py-1 border-t border-green-500/10 bg-black/20 backdrop-blur-sm">
    <span class="font-mono text-xs text-green-500/30 flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-green-400/50 animate-pulse"></span>
      PENTESTING · CIBERSEGURIDAD · RESPUESTA A INCIDENTES
    </span>
    <span id="hud-packets" class="font-mono text-xs text-green-500/25 tabular-nums">PKT: 000000</span>
    <span class="font-mono text-xs text-green-500/30">ENCRIPTADO · AES-256-GCM</span>
  </div>

  {/* ============================================================ */}
  {/* CONTENIDO PRINCIPAL                                          */}
  {/* ============================================================ */}
  <main class="px-4 relative" style="z-index: 2;">
    <SectionContainer class="py-16 md:py-36">
      <Hero>
        </slot>
      </Hero>
    </SectionContainer>

    <div class="space-y-24">

      <!--

      <SectionContainer id="information">
        <div class="hacker-section-wrapper reveal-section">
          <TitleSection>
            <Bulb class="size-7" />
            <span class="glitch-title typewriter-title" data-text="Presentación del portafolio">Presentación del portafolio</span>
          </TitleSection>
          <Information />
        </div>
      </SectionContainer>

      -->

      {/* --- EXPERIENCIA --- */}
      <SectionContainer id="experiencia">
        <div class="hacker-section-wrapper reveal-section">
          <TitleSection>
            <Briefcase class="size-8" />
            <span class="glitch-title typewriter-title" data-text="Experiencia">Experiencia</span>
          </TitleSection>
          <Experience />
        </div>
      </SectionContainer>

      {/* --- CERTIFICADOS --- */}
      <SectionContainer id="awards">
        <div class="hacker-section-wrapper reveal-section">
          <TitleSection>
            <Certificate class="size-7" />
            <span class="glitch-title typewriter-title" data-text="Certificados">Certificados</span>
          </TitleSection>
          <Awards />
        </div>
      </SectionContainer>

      {/* ============================================================ */}
      {/* SECCIÓN DE PROYECTOS                                         */}
      {/* ============================================================ */}
      <SectionContainer id="proyectos">
        <div class="hacker-section-wrapper reveal-section">
          <TitleSection>
            <CodeIcon class="size-7" />
            <span class="glitch-title typewriter-title" data-text="Proyectos">Proyectos</span>
          </TitleSection>
        </div>

        <div class="mt-8">
          <Projects />

          {/* TERMINAL — ESPERANDO MÁS PROYECTOS */}
          <div class="terminal-waiting mt-12">
            <div class="terminal-scanline"></div>
            <div class="terminal-top-bar">
              <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
              <span class="w-3 h-3 rounded-full bg-yellow-500/60"></span>
              <span class="w-3 h-3 rounded-full bg-green-500/60"></span>
              <span class="font-mono text-xs text-gray-500 ml-2">bash — osvaldo@kali</span>
            </div>
            <CodeIcon class="size-8 text-gray-400 dark:text-green-500/50 mb-3" />
            <p class="text-base text-gray-600 dark:text-green-400 font-mono text-center">
              root@osvaldo-pc:~# esperando_mas_proyectos<span class="terminal-cursor">_</span>
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-600 font-mono text-center mt-2 animate-pulse">[ ACCESO RESTRINGIDO - ESPERANDO INSTRUCCIONES ]</p>
          </div>
        </div>
      </SectionContainer>

      {/* --- SOBRE MÍ --- */}
      <SectionContainer id="sobre-mi">
        <div class="hacker-section-wrapper reveal-section">
          <TitleSection>
            <ProfileCheck class="size-8" />
            <span class="glitch-title typewriter-title" data-text="Sobre mí">Sobre mí</span>
          </TitleSection>
          <AboutMe />
        </div>
      </SectionContainer>

      {/* --- INFO TÉCNICA --- */}
      <SectionContainer id="create">
        <div class="hacker-section-wrapper reveal-section">
          <TitleSection>
            <CodeIcon1 class="size-7" />
            <span class="glitch-title typewriter-title" data-text="Información técnica básica">Información técnica básica</span>
          </TitleSection>
          <Create />
        </div>
      </SectionContainer>

      {/* --- CONTACTO --- */}
      <SectionContainer id="contacto">
        <div class="reveal-section">
          <Contacto />
        </div>
      </SectionContainer>

    </div>
  </main>
</Layout>

{/* ================================================================ */}
{/* ESTILOS GLOBALES HACKER (BASE) + MEJORAS                        */}
{/* ================================================================ */}
<style is:global>

  /* ---- MATRIX CANVAS ---- */
  #matrix-canvas {
    image-rendering: pixelated;
  }

  /* ---- SCANLINES CRT ---- */
  #scanlines {
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 65, 0.03) 2px,
      rgba(0, 255, 65, 0.03) 4px
    );
    pointer-events: none;
  }

  /* ---- GLITCH EN TÍTULOS ---- */
  .glitch-title {
    position: relative;
    display: inline-block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .glitch-title:hover::before,
    .glitch-title:hover::after {
      content: attr(data-text);
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }

    .glitch-title:hover::before {
      color: #00ff41;
      animation: glitch-1 0.3s infinite linear;
      clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
      opacity: 0.7;
    }

    .glitch-title:hover::after {
      color: #ff003c;
      animation: glitch-2 0.3s infinite linear;
      clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
      opacity: 0.7;
    }
  }

  @keyframes glitch-1 {
    0%   { transform: translate(0); }
    20%  { transform: translate(-2px, 1px); }
    40%  { transform: translate(2px, -1px); }
    60%  { transform: translate(-1px, 2px); }
    80%  { transform: translate(1px, -2px); }
    100% { transform: translate(0); }
  }

  @keyframes glitch-2 {
    0%   { transform: translate(0); }
    20%  { transform: translate(2px, -1px); }
    40%  { transform: translate(-2px, 1px); }
    60%  { transform: translate(1px, -2px); }
    80%  { transform: translate(-1px, 2px); }
    100% { transform: translate(0); }
  }

  /* ---- CURSOR PARPADEANTE ---- */
  .terminal-cursor {
    display: inline-block;
    animation: blink 1s step-end infinite;
    color: #00ff41;
    font-weight: bold;
  }

  .terminal-cursor--red {
    color: #ff003c;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ---- TERMINAL ---- */
  .terminal-waiting {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1rem 2rem;
    border: 1px dashed rgba(0, 255, 65, 0.25);
    border-radius: 0.75rem;
    background-color: #0d1117;
    position: relative;
    overflow: hidden;
  }

  .dark .terminal-waiting {
    border-color: rgba(0, 255, 65, 0.2);
  }

  .terminal-waiting--locked {
    border-color: rgba(255, 0, 60, 0.2) !important;
    background-color: #100808 !important;
  }

  .terminal-waiting::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 65, 0.6), transparent);
  }

  .terminal-waiting--locked::before {
    background: linear-gradient(90deg, transparent, rgba(255, 0, 60, 0.5), transparent) !important;
  }

  .terminal-scanline {
    position: absolute;
    top: -100%;
    left: 0;
    right: 0;
    height: 40px;
    background: linear-gradient(transparent, rgba(0, 255, 65, 0.04), transparent);
    animation: scan 4s linear infinite;
    pointer-events: none;
  }

  @keyframes scan {
    0%   { top: -10%; }
    100% { top: 110%; }
  }

  .terminal-top-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: rgba(0, 0, 0, 0.4);
    border-bottom: 1px solid rgba(0, 255, 65, 0.08);
    margin-bottom: 1rem;
  }

  .terminal-waiting > *:not(.terminal-top-bar):not(.terminal-scanline) {
    margin-top: 0.5rem;
  }

  .dark .hacker-section-wrapper {
    transition: box-shadow 0.3s ease;
  }

  .dark .hacker-section-wrapper:hover {
    box-shadow: 0 0 20px -4px rgba(0, 255, 65, 0.06);
  }

  .lock-icon {
    animation: lock-shake 5s ease-in-out infinite;
  }

  @keyframes lock-shake {
    0%, 90%, 100% { transform: rotate(0deg); }
    92%            { transform: rotate(-5deg); }
    94%            { transform: rotate(5deg); }
    96%            { transform: rotate(-3deg); }
    98%            { transform: rotate(3deg); }
  }

  /* ============================================================ */
  /* MEJORA 2 — ANIMACIONES DE ENTRADA POR SECCIÓN                */
  /* ============================================================ */

  .reveal-section {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-section::before {
    content: '';
    display: block;
    height: 1px;
    width: 0%;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 65, 0.45), transparent);
    margin-bottom: 1.5rem;
    transition: width 0.75s ease 0.15s;
  }

  .reveal-section.is-visible::before {
    width: 100%;
  }

</style>

{/* ================================================================ */}
{/* SCRIPTS                                                          */}
{/* ================================================================ */}
<script>
  /* ============================================================
     BASE — MATRIX RAIN
  ============================================================ */
  (function initMatrix() {
    const canvas = document.getElementById('matrix-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789<>{}[]|/\\#@$%^&*~'.split('');
    const fontSize = 14;
    let drops: number[] = [];

    function resize() {
      canvas.width  = window.innerWidth;
      canvas.height = window.innerHeight;
      const cols = Math.floor(canvas.width / fontSize);
      drops = Array.from({ length: cols }, () => Math.random() * -canvas.height);
    }

    resize();
    window.addEventListener('resize', resize);

    function draw() {
      if (!ctx) return;
      ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.font = `${fontSize}px monospace`;

      drops.forEach((y, i) => {
        const char  = chars[Math.floor(Math.random() * chars.length)];
        const x     = i * fontSize;
        const ratio = y / canvas.height;
        ctx.fillStyle = ratio > 0.8 ? '#ffffff' : `rgba(0, 255, 65, ${0.3 + ratio * 0.5})`;
        if (y > 0) ctx.fillText(char, x, y);
        drops[i] += fontSize;
        if (drops[i] > canvas.height + fontSize * 5) {
          drops[i] = Math.random() * -canvas.height * 0.5;
        }
      });
    }

    setInterval(draw, 50);
  })();

  /* ============================================================
     BASE — HUD RELOJ
  ============================================================ */
  (function initClock() {
    const el = document.getElementById('hud-time');
    if (!el) return;
    function tick() {
      if (!el) return;
      const now = new Date();
      const h   = String(now.getHours()).padStart(2, '0');
      const m   = String(now.getMinutes()).padStart(2, '0');
      const s   = String(now.getSeconds()).padStart(2, '0');
      el.textContent = `${h}:${m}:${s}`;
    }
    tick();
    setInterval(tick, 1000);
  })();

  /* ============================================================
     BASE — HUD PACKETS COUNTER (fake, estético)
  ============================================================ */
  (function initPackets() {
    const el = document.getElementById('hud-packets');
    if (!el) return;
    let count = Math.floor(Math.random() * 99999);
    setInterval(() => {
      if (!el) return;
      count += Math.floor(Math.random() * 50) + 1;
      el.textContent = `PKT: ${String(count).padStart(6, '0')}`;
    }, 200);
  })();

  /* ============================================================
     MEJORA 1 — BARRA DE PROGRESO DE SCROLL NEÓN
     CORRECCIÓN: el guard "if (!el) return" se aplica también
     dentro del closure update(), ya que TypeScript no puede
     garantizar que el elemento siga existiendo en ese scope.
  ============================================================ */
  (function initScrollProgress() {
    const el = document.getElementById('scroll-progress');
    if (!el) return;

    function update() {
      if (!el) return;                          // ← guard dentro del closure
      const scrolled  = window.scrollY;
      const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
      const pct       = maxScroll > 0 ? (scrolled / maxScroll) * 100 : 0;
      el.style.width  = `${pct}%`;
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  })();

  /* ============================================================
     MEJORA 2 — ANIMACIONES DE ENTRADA (Intersection Observer)
  ============================================================ */
  (function initReveal() {
    const elements = document.querySelectorAll('.reveal-section');
    if (!elements.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08 }
    );

    elements.forEach((el) => observer.observe(el));
  })();

  /* ============================================================
     MEJORA 3 — CURSOR GLOW (solo desktop con mouse fino)
  ============================================================ */
  (function initCursorGlow() {
    const glow = document.getElementById('cursor-glow');
    if (!glow) return;
    if (!window.matchMedia('(pointer: fine)').matches) return;

    document.addEventListener('mousemove', (e) => {
      if (!glow) return;
      glow.style.left = `${e.clientX}px`;
      glow.style.top  = `${e.clientY}px`;
    }, { passive: true });
  })();

  /* ============================================================
     MEJORA 4 — EFECTO TYPEWRITER EN TÍTULOS DE SECCIÓN
  ============================================================ */
  (function initTypewriter() {
    const titles = document.querySelectorAll<HTMLElement>('.typewriter-title');
    if (!titles.length) return;

    function typewrite(el: HTMLElement) {
      const full = el.getAttribute('data-text') ?? el.textContent ?? '';
      el.textContent = '';
      let i = 0;

      const cursor = document.createElement('span');
      cursor.className = 'terminal-cursor';
      cursor.textContent = '_';
      el.appendChild(cursor);

      const interval = setInterval(() => {
        if (i < full.length) {
          el.insertBefore(document.createTextNode(full[i]), cursor);
          i++;
        } else {
          clearInterval(interval);
          cursor.remove();
        }
      }, 38);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            observer.unobserve(entry.target);
            setTimeout(() => typewrite(entry.target as HTMLElement), 220);
          }
        });
      },
      { threshold: 0.5 }
    );

    titles.forEach((el) => observer.observe(el));
  })();
</script>